        RECT 4.000 23.440 69.715 24.840 ;
        RECT 4.000 21.440 70.115 23.440 ;
        RECT 4.000 20.040 69.715 21.440 ;
        RECT 4.000 18.040 70.115 20.040 ;
        RECT 4.000 16.640 69.715 18.040 ;
        RECT 4.000 14.640 70.115 16.640 ;
        RECT 4.000 13.240 69.715 14.640 ;
        RECT 4.000 11.240 70.115 13.240 ;
